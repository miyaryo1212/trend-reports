---
import Base from './Base.astro';

interface Props {
  title: string;
  channel: string;
  date: Date;
}

const { title, channel, date } = Astro.props;
const dateStr = date.toISOString().slice(0, 10);
---

<Base title={title}>
  <nav><a href="/">&larr; レポート一覧</a></nav>
  <header>
    <h1>{channel}</h1>
    <time datetime={dateStr}>{dateStr}</time>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <p>Generated by <a href="https://github.com/anthropics/claude-code">Claude Code</a></p>
  </footer>
</Base>
