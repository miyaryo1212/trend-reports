---
import Base from './Base.astro';
import ChannelLogo from '../components/ChannelLogo.astro';

interface Props {
  title: string;
  channel: string;
  date: Date;
  summary?: string;
  importance?: number;
}

const { title, channel, date, summary, importance } = Astro.props;
const dateStr = date.toISOString().slice(0, 10);
const pageUrl = Astro.url.href;
const tweetText = `${channel}のAIトレンドレポート（${dateStr}）`;
const tweetUrl = `https://x.com/intent/tweet?text=${encodeURIComponent(tweetText + '\n')}&url=${encodeURIComponent(pageUrl)}`;
const description = summary ?? `${channel}の${dateStr}のAIトレンドレポートです。`;
---

<Base title={title} description={description} ogType="article">
  <nav><a href="/">&larr; レポート一覧</a></nav>
  <header>
    <h1>{title}</h1>
    <time datetime={dateStr}>{dateStr}</time>
  </header>
  <div class="share-buttons">
    <a href={tweetUrl} target="_blank" rel="noopener noreferrer" class="share-btn share-btn-x">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="13" height="13"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      <span class="share-btn-label">Xでシェア</span>
    </a>
    <button class="share-btn share-btn-copy" data-url={pageUrl}>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      <span class="share-btn-label">URLをコピー</span>
    </button>
  </div>
  <main data-pagefind-body>
    {summary && (
      <div class="report-summary">
        <span class="report-summary-title"><ChannelLogo id="claude-anthropic" size={14} /> Summary by Claude Code</span>
        <p>{summary}</p>
        {importance && (
          <div class="report-importance">
            <span class="report-importance-label">注目度</span>
            <span class="stars" aria-label={`${importance}/5`}>
              {Array.from({ length: 5 }).map((_, i) => (
                <span class={i < importance ? 'star filled' : 'star'} aria-hidden="true">★</span>
              ))}
            </span>
          </div>
        )}
      </div>
    )}
    <slot />
  </main>
  <div class="share-buttons share-buttons-bottom">
    <a href={tweetUrl} target="_blank" rel="noopener noreferrer" class="share-btn share-btn-x">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="13" height="13"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      <span class="share-btn-label">Xでシェア</span>
    </a>
    <button class="share-btn share-btn-copy" data-url={pageUrl}>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      <span class="share-btn-label">URLをコピー</span>
    </button>
  </div>
</Base>

<script>
  document.querySelectorAll<HTMLButtonElement>('.share-btn-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.url;
      if (!url) return;
      try {
        await navigator.clipboard.writeText(url);
        const label = btn.querySelector('.share-btn-label');
        if (label) {
          const original = label.textContent;
          label.textContent = 'コピーしました！';
          setTimeout(() => { label.textContent = original; }, 2000);
        }
      } catch {
        // clipboard API unavailable
      }
    });
  });
</script>
