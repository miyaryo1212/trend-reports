---
import Base from './Base.astro';

interface Props {
  title: string;
  channel: string;
  date: Date;
  summary?: string;
  importance?: number;
}

const { title, channel, date, summary, importance } = Astro.props;
const dateStr = date.toISOString().slice(0, 10);
const pageUrl = Astro.url.href;
const tweetText = `${channel}のAIトレンドレポート（${dateStr}）`;
const tweetUrl = `https://x.com/intent/tweet?text=${encodeURIComponent(tweetText + '\n')}&url=${encodeURIComponent(pageUrl)}`;
const description = summary ?? `${channel}の${dateStr}のAIトレンドレポートです。`;
---

<Base title={title} description={description} ogType="article">
  <nav><a href="/">&larr; レポート一覧</a></nav>
  <header>
    <h1>{title}</h1>
    <time datetime={dateStr}>{dateStr}</time>
  </header>
  <div class="share-buttons">
    <a href={tweetUrl} target="_blank" rel="noopener noreferrer" class="share-btn share-btn-x">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="13" height="13"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      <span class="share-btn-label">Xでシェア</span>
    </a>
    <button class="share-btn share-btn-copy" data-url={pageUrl}>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      <span class="share-btn-label">URLをコピー</span>
    </button>
  </div>
  <main data-pagefind-body>
    {summary && (
      <div class="report-summary">
        <span class="report-summary-title"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="14" height="14"><path d="m3.127 10.604 3.135-1.76.053-.153-.053-.085H6.11l-.525-.032-1.791-.048-1.554-.065-1.505-.08-.38-.081L0 7.832l.036-.234.32-.214.455.04 1.009.069 1.513.105 1.097.064 1.626.17h.259l.036-.105-.089-.065-.068-.064-1.566-1.062-1.695-1.121-.887-.646-.48-.327-.243-.306-.104-.67.435-.48.585.04.15.04.593.456 1.267.981 1.654 1.218.242.202.097-.068.012-.049-.109-.181-.9-1.626-.96-1.655-.428-.686-.113-.411a2 2 0 0 1-.068-.484l.496-.674L4.446 0l.662.089.279.242.411.94.666 1.48 1.033 2.014.302.597.162.553.06.17h.105v-.097l.085-1.134.157-1.392.154-1.792.052-.504.25-.605.497-.327.387.186.319.456-.045.294-.19 1.23-.37 1.93-.243 1.29h.142l.161-.16.654-.868 1.097-1.372.484-.545.565-.601.363-.287h.686l.505.751-.226.775-.707.895-.585.759-.839 1.13-.524.904.048.072.125-.012 1.897-.403 1.024-.186 1.223-.21.553.258.06.263-.218.536-1.307.323-1.533.307-2.284.54-.028.02.032.04 1.029.098.44.024h1.077l2.005.15.525.346.315.424-.053.323-.807.411-3.631-.863-.872-.218h-.12v.073l.726.71 1.331 1.202 1.667 1.55.084.383-.214.302-.226-.032-1.464-1.101-.565-.497-1.28-1.077h-.084v.113l.295.432 1.557 2.34.08.718-.112.234-.404.141-.444-.08-.911-1.28-.94-1.44-.759-1.291-.093.053-.448 4.821-.21.246-.484.186-.403-.307-.214-.496.214-.98.258-1.28.21-1.016.19-1.263.112-.42-.008-.028-.092.012-.953 1.307-1.448 1.957-1.146 1.227-.274.109-.477-.247.045-.44.266-.39 1.586-2.018.956-1.25.617-.723-.004-.105h-.036l-4.212 2.736-.75.096-.324-.302.04-.496.154-.162 1.267-.871z"/></svg> Summary by Claude Code</span>
        <p>{summary}</p>
        {importance && (
          <div class="report-importance">
            <span class="report-importance-label">注目度</span>
            <span class="stars">
              {Array.from({ length: 5 }).map((_, i) => (
                <span class={i < importance ? 'star filled' : 'star'}>★</span>
              ))}
            </span>
          </div>
        )}
      </div>
    )}
    <slot />
  </main>
  <div class="share-buttons share-buttons-bottom">
    <a href={tweetUrl} target="_blank" rel="noopener noreferrer" class="share-btn share-btn-x">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="13" height="13"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      <span class="share-btn-label">Xでシェア</span>
    </a>
    <button class="share-btn share-btn-copy" data-url={pageUrl}>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      <span class="share-btn-label">URLをコピー</span>
    </button>
  </div>
</Base>

<script>
  document.querySelectorAll<HTMLButtonElement>('.share-btn-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.url;
      if (!url) return;
      try {
        await navigator.clipboard.writeText(url);
        const label = btn.querySelector('.share-btn-label');
        if (label) {
          const original = label.textContent;
          label.textContent = 'コピーしました！';
          setTimeout(() => { label.textContent = original; }, 2000);
        }
      } catch {
        // clipboard API unavailable
      }
    });
  });
</script>
