---
import Base from './Base.astro';

interface Props {
  title: string;
  channel: string;
  date: Date;
}

const { title, channel, date } = Astro.props;
const dateStr = date.toISOString().slice(0, 10);
---

<Base title={title}>
  <nav><a href="/">&larr; レポート一覧</a></nav>
  <header>
    <h1>{title}</h1>
    <time datetime={dateStr}>{dateStr}</time>
  </header>
  <main data-pagefind-body>
    <slot />
  </main>
</Base>
