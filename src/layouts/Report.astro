---
import Base from './Base.astro';
import ChannelLogo from '../components/ChannelLogo.astro';

interface Props {
  title: string;
  channel: string;
  date: Date;
  summary?: string;
  importance?: number;
  codexReview?: string;
  codexImportance?: number;
}

const { title, channel, date, summary, importance, codexReview, codexImportance } = Astro.props;
const hasCodex = !!codexReview;
const dateStr = date.toISOString().slice(0, 10);
const pageUrl = Astro.url.href;
const tweetText = `${channel}のAIトレンドレポート（${dateStr}）`;
const tweetUrl = `https://x.com/intent/tweet?text=${encodeURIComponent(tweetText + '\n')}&url=${encodeURIComponent(pageUrl)}`;
const description = summary ?? `${channel}の${dateStr}のAIトレンドレポートです。`;
---

<Base title={title} description={description} ogType="article">
  <nav><a href="/">&larr; レポート一覧</a></nav>
  <header class="report-header">
    <h1>{channel}</h1>
    <time class="report-date" datetime={dateStr}>{dateStr}</time>
  </header>
  <div class="share-buttons">
    <a href={tweetUrl} target="_blank" rel="noopener noreferrer" class="share-btn share-btn-x">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="13" height="13"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      <span class="share-btn-label">Xでシェア</span>
    </a>
    <button class="share-btn share-btn-copy" data-url={pageUrl}>
      <svg class="share-btn-icon-default" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      <svg class="share-btn-icon-success" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="13" height="13" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
      <span class="share-btn-label" aria-live="polite">URLをコピー</span>
    </button>
  </div>
  <main data-pagefind-body>
    {summary && (
      <div class="report-summary" data-view="claude" data-has-codex={hasCodex ? 'true' : 'false'}>
        {hasCodex && (
          <div class="review-toggle" role="tablist" aria-label="レビュー切替">
            <button
              class="review-toggle-btn is-active"
              role="tab"
              aria-selected="true"
              data-view-target="claude"
              type="button"
            >
              <ChannelLogo id="claude-anthropic" size={12} />
              <span>Summary<span class="review-toggle-suffix"> by Claude Code</span></span>
            </button>
            <button
              class="review-toggle-btn"
              role="tab"
              aria-selected="false"
              data-view-target="codex"
              type="button"
            >
              <ChannelLogo id="codex-openai" size={12} />
              <span>Review<span class="review-toggle-suffix"> by Codex</span></span>
            </button>
            <span class="review-toggle-pill" aria-hidden="true"></span>
          </div>
        )}

        {!hasCodex && (
          <span class="report-summary-title">
            <ChannelLogo id="claude-anthropic" size={14} /> Summary by Claude Code
          </span>
        )}

        <div class="review-panes">
          <p class="review-pane review-pane-claude" data-view="claude">{summary}</p>
          {hasCodex && (
            <p class="review-pane review-pane-codex" data-view="codex" aria-hidden="true">{codexReview}</p>
          )}
        </div>

        {(importance || codexImportance) && (
          <div class="report-importance">
            <span class="report-importance-label">注目度</span>
            {importance && (
              <span class="stars review-pane" data-view="claude" aria-label={`${importance}/5`}>
                {Array.from({ length: 5 }).map((_, i) => (
                  <span class={i < importance ? 'star filled' : 'star'} aria-hidden="true">★</span>
                ))}
              </span>
            )}
            {hasCodex && codexImportance && (
              <span class="stars review-pane" data-view="codex" aria-label={`${codexImportance}/5`} aria-hidden="true">
                {Array.from({ length: 5 }).map((_, i) => (
                  <span class={i < codexImportance ? 'star filled' : 'star'} aria-hidden="true">★</span>
                ))}
              </span>
            )}
          </div>
        )}
      </div>
    )}
    <slot />
  </main>
  <div class="share-buttons share-buttons-bottom">
    <a href={tweetUrl} target="_blank" rel="noopener noreferrer" class="share-btn share-btn-x">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="13" height="13"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      <span class="share-btn-label">Xでシェア</span>
    </a>
    <button class="share-btn share-btn-copy" data-url={pageUrl}>
      <svg class="share-btn-icon-default" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      <svg class="share-btn-icon-success" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="13" height="13" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
      <span class="share-btn-label" aria-live="polite">URLをコピー</span>
    </button>
  </div>
</Base>

<script>
  // Summary (Claude) / Review (Codex) toggle
  const summaryBox = document.querySelector<HTMLElement>('.report-summary[data-has-codex="true"]');
  if (summaryBox) {
    const root = document.documentElement;
    const buttons = summaryBox.querySelectorAll<HTMLButtonElement>('.review-toggle-btn');
    const setView = (view: 'claude' | 'codex') => {
      summaryBox.dataset.view = view;
      root.dataset.reviewSource = view;
      buttons.forEach((b) => {
        const isActive = b.dataset.viewTarget === view;
        b.classList.toggle('is-active', isActive);
        b.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
      summaryBox.querySelectorAll<HTMLElement>('.review-pane').forEach((el) => {
        el.setAttribute('aria-hidden', el.dataset.view === view ? 'false' : 'true');
      });
    };
    buttons.forEach((b) => {
      b.addEventListener('click', () => setView(b.dataset.viewTarget as 'claude' | 'codex'));
    });
    // Initial: Claude
    root.dataset.reviewSource = 'claude';
  }

  document.querySelectorAll<HTMLButtonElement>('.share-btn-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.url;
      if (!url) return;
      try {
        await navigator.clipboard.writeText(url);
        const label = btn.querySelector('.share-btn-label');
        if (!label) return;
        const original = label.textContent;
        label.textContent = 'コピーしました';
        btn.classList.add('is-copied');
        setTimeout(() => {
          label.textContent = original;
          btn.classList.remove('is-copied');
        }, 1800);
      } catch {
        // clipboard API unavailable
      }
    });
  });
</script>
