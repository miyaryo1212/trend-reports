---
---
<div class="consent-banner" id="consent-banner" role="dialog" aria-labelledby="consent-title" aria-describedby="consent-desc" hidden>
  <div class="consent-banner-inner">
    <div class="consent-banner-text">
      <strong id="consent-title">Cookie の利用について</strong>
      <p id="consent-desc">
        当サイトはアクセス解析のため Google Analytics を利用しています。許可をいただいた場合のみ計測を行います。詳細は
        <a href="/privacy/">プライバシーポリシー</a> / <a href="/cookies/">Cookieポリシー</a> をご覧ください。
      </p>
    </div>
    <div class="consent-banner-actions">
      <button type="button" class="consent-btn consent-btn-deny" id="consent-deny">拒否する</button>
      <button type="button" class="consent-btn consent-btn-accept" id="consent-accept">許可する</button>
    </div>
  </div>
</div>

<script>
  const STORAGE_KEY = 'consent';
  const banner = document.getElementById('consent-banner');
  const acceptBtn = document.getElementById('consent-accept');
  const denyBtn = document.getElementById('consent-deny');

  function readConsent(): 'granted' | 'denied' | null {
    try {
      const v = localStorage.getItem(STORAGE_KEY);
      return v === 'granted' || v === 'denied' ? v : null;
    } catch {
      return null;
    }
  }

  function writeConsent(value: 'granted' | 'denied') {
    try { localStorage.setItem(STORAGE_KEY, value); } catch {}
  }

  function updateGtagConsent(value: 'granted' | 'denied') {
    const w = window as unknown as { gtag?: (...args: unknown[]) => void };
    if (typeof w.gtag === 'function') {
      w.gtag('consent', 'update', {
        analytics_storage: value,
        ad_storage: value,
        ad_user_data: value,
        ad_personalization: value,
      });
    }
  }

  function hideBanner() {
    if (banner) banner.hidden = true;
  }

  function showBanner() {
    if (banner) banner.hidden = false;
  }

  function apply(value: 'granted' | 'denied') {
    writeConsent(value);
    updateGtagConsent(value);
    hideBanner();
  }

  const current = readConsent();
  if (current === null) {
    showBanner();
  } else {
    updateGtagConsent(current);
  }

  acceptBtn?.addEventListener('click', () => apply('granted'));
  denyBtn?.addEventListener('click', () => apply('denied'));
</script>

<style>
  .consent-banner {
    position: fixed;
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    z-index: 1000;
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: 10px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    padding: 1rem 1.1rem;
  }
  .consent-banner[hidden] {
    display: none;
  }
  .consent-banner-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .consent-banner-text {
    flex: 1 1 320px;
    min-width: 0;
  }
  .consent-banner-text strong {
    display: block;
    font-size: 0.92rem;
    margin-bottom: 0.2rem;
  }
  .consent-banner-text p {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.55;
  }
  .consent-banner-text a {
    color: var(--link);
  }
  .consent-banner-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .consent-btn {
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    cursor: pointer;
    font-family: inherit;
  }
  .consent-btn-deny {
    background: var(--surface);
    color: var(--fg);
  }
  .consent-btn-deny:hover {
    background: var(--border);
  }
  .consent-btn-accept {
    background: var(--brand);
    color: #fff;
    border-color: var(--brand);
  }
  .consent-btn-accept:hover {
    opacity: 0.9;
  }
  @media (max-width: 600px) {
    .consent-banner {
      left: 0.5rem;
      right: 0.5rem;
      bottom: 0.5rem;
      padding: 0.9rem 1rem;
    }
    .consent-banner-inner {
      flex-direction: column;
      align-items: stretch;
    }
    .consent-banner-actions {
      justify-content: flex-end;
    }
  }
</style>
