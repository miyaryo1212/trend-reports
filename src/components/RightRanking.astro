---
import { getCollection } from 'astro:content';
import ranking from '../data/ranking.json';
import ChannelLogo from './ChannelLogo.astro';

const reports = await getCollection('reports');
const reportMap = new Map(reports.map((r) => [r.id, r]));

type RankingItem = { rank: number; slug: string; reason: string };
const aiItems = (ranking.items as RankingItem[])
  .map((item) => ({ item, report: reportMap.get(item.slug) }))
  .filter((x): x is { item: RankingItem; report: (typeof reports)[number] } => !!x.report);

const hasAI = aiItems.length > 0;

// Period window in JST calendar days. Build server is UTC on Cloudflare
// Pages, so compute today in Asia/Tokyo explicitly and use midnight-UTC
// Date objects (which is how frontmatter dates are stored).
const jstDateFormatter = new Intl.DateTimeFormat('en-CA', {
  timeZone: 'Asia/Tokyo',
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
const [jstY, jstM, jstD] = jstDateFormatter.format(new Date()).split('-').map(Number);
const periodEndDate = new Date(Date.UTC(jstY, jstM - 1, jstD));
const periodStartDate = new Date(Date.UTC(jstY, jstM - 1, jstD - 27));

const fallbackRanked = reports
  .slice()
  .filter((r) => r.data.date >= periodStartDate && r.data.date <= periodEndDate)
  .sort((a, b) => {
    const impDiff = (b.data.importance ?? 0) - (a.data.importance ?? 0);
    if (impDiff !== 0) return impDiff;
    return b.data.date.valueOf() - a.data.date.valueOf();
  })
  .slice(0, 5);

const displayItems = hasAI
  ? aiItems.map(({ item, report }) => ({ report, reason: item.reason, rank: item.rank }))
  : fallbackRanked.map((report, i) => ({ report, reason: '', rank: i + 1 }));
---

<aside class="right-ranking" aria-label="注目レポート">
  <div class="ranking-header">
    <span class="ranking-title-icon">
      <ChannelLogo id="claude-anthropic" size={14} />
    </span>
    <span class="ranking-title">Picks by Claude Code</span>
  </div>
  <div class="ranking-sub">直近4週間 Top {displayItems.length}</div>
  <ol class="ranking-list">
    {displayItems.map(({ report, reason, rank }) => {
      const dateStr = report.data.date.toISOString().slice(0, 10);
      return (
        <li>
          <a href={`/reports/${report.id}/`}>
            <span class="ranking-rank">{rank}</span>
            <div class="ranking-body">
              <div class="ranking-meta">
                <span class="channel-badge">
                  <ChannelLogo id={report.data.channelId} />
                  {report.data.channel}
                </span>
                {report.data.importance && (
                  <span class="ranking-stars" aria-label={`注目度 ${report.data.importance}/5`}>
                    <span aria-hidden="true">{'★'.repeat(report.data.importance)}</span>
                  </span>
                )}
              </div>
              <div class="ranking-title-text">{report.data.title}</div>
              {reason && <div class="ranking-reason">{reason}</div>}
              <div class="ranking-date">{dateStr}</div>
            </div>
          </a>
        </li>
      );
    })}
  </ol>
</aside>
