---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const reports = await getCollection('reports');
const sorted = reports.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const channelOrder = ['Claude Code', 'Codex / OpenAI', '生成AIトレンド総合', 'GitHub急成長リポ'];
const channels = channelOrder.filter(ch =>
  sorted.some(r => r.data.channel === ch)
);
---

<Base title="AI Trend Reports">
  <header>
    <h1>AI Trend Reports</h1>
    <p>生成AI関連のトレンド調査レポート</p>
  </header>
  <main>
    <div class="filters">
      <div class="filter-group">
        <label>チャネル</label>
        <div class="channel-tabs">
          <button class="tab active" data-channel="all">すべて</button>
          {channels.map((ch) => (
            <button class="tab" data-channel={ch}>{ch}</button>
          ))}
        </div>
      </div>
      <div class="filter-group">
        <label>期間</label>
        <div class="date-range">
          <span class="date-label">From</span>
          <input type="date" id="date-from" />
          <span class="date-label">to</span>
          <input type="date" id="date-to" />
          <button id="date-reset" class="reset-btn">Reset</button>
        </div>
      </div>
      <div class="filter-group">
        <label>検索</label>
        <div id="search"></div>
      </div>
    </div>

    {sorted.length === 0 ? (
      <p>レポートはまだありません。</p>
    ) : (
      <ul class="report-list" id="report-list">
        {sorted.map((report) => {
          const dateStr = report.data.date.toISOString().slice(0, 10);
          return (
            <li data-channel={report.data.channel} data-date={dateStr}>
              <span class="channel-badge">{report.data.channel}</span>
              <a href={`/reports/${report.id}/`}>{report.data.title}</a>
              <span class="date">{dateStr}</span>
            </li>
          );
        })}
      </ul>
    )}
    <p class="no-results" style="display:none;">該当するレポートはありません。</p>
  </main>
</Base>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script is:inline src="/pagefind/pagefind-ui.js"></script>
<script is:inline>
  // Pagefind search
  window.addEventListener('DOMContentLoaded', () => {
    new PagefindUI({
      element: '#search',
      showSubResults: true,
      showImages: false,
      translations: {
        placeholder: 'レポート内を検索...',
        zero_results: '「[SEARCH_TERM]」に一致する結果はありません',
      },
    });
  });
</script>

<script>
  // Channel & date filters
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab');
  const dateFrom = document.getElementById('date-from') as HTMLInputElement;
  const dateTo = document.getElementById('date-to') as HTMLInputElement;
  const dateReset = document.getElementById('date-reset');
  const items = document.querySelectorAll<HTMLLIElement>('.report-list li');
  const noResults = document.querySelector<HTMLElement>('.no-results');

  let activeChannel = 'all';

  function applyFilters() {
    const from = dateFrom.value;
    const to = dateTo.value;
    let visibleCount = 0;

    items.forEach((item) => {
      const ch = item.dataset.channel;
      const date = item.dataset.date!;

      const matchChannel = activeChannel === 'all' || ch === activeChannel;
      const matchFrom = !from || date >= from;
      const matchTo = !to || date <= to;

      if (matchChannel && matchFrom && matchTo) {
        item.style.display = '';
        visibleCount++;
      } else {
        item.style.display = 'none';
      }
    });

    if (noResults) {
      noResults.style.display = visibleCount === 0 ? '' : 'none';
    }
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');
      activeChannel = tab.dataset.channel!;
      applyFilters();
    });
  });

  dateFrom.addEventListener('change', applyFilters);
  dateTo.addEventListener('change', applyFilters);
  dateReset?.addEventListener('click', () => {
    dateFrom.value = '';
    dateTo.value = '';
    applyFilters();
  });
</script>
