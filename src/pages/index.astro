---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ChannelLogo from '../components/ChannelLogo.astro';

const reports = await getCollection('reports');
const sorted = reports.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const channelOrder = ['Claude / Anthropic', 'Codex / OpenAI', '生成AIトレンド総合', 'GitHub急成長リポ', 'LLM/NLP最新論文'];
const channels = channelOrder.filter(ch =>
  sorted.some(r => r.data.channel === ch)
);
---

<Base title="AI Trend Reports">
  <header>
    <h1>AI Trend Reports</h1>
    <p>生成AI関連のトレンド調査レポート</p>
  </header>
  <div class="channel-schedule">
    <div class="schedule-section">
      <span class="schedule-label">Daily</span>
      <ul>
        <li><span class="channel-badge"><ChannelLogo id="claude-anthropic" />Claude / Anthropic</span><span class="schedule-freq">6時頃</span></li>
        <li><span class="channel-badge"><ChannelLogo id="codex-openai" />Codex / OpenAI</span><span class="schedule-freq">6時半頃</span></li>
        <li><span class="channel-badge"><ChannelLogo id="ai-trends" />生成AIトレンド総合</span><span class="schedule-freq">7時頃</span></li>
        <li><span class="channel-badge"><ChannelLogo id="academia" />LLM/NLP最新論文</span><span class="schedule-freq">7時半頃</span></li>
      </ul>
    </div>
    <div class="schedule-section">
      <span class="schedule-label">Weekly</span>
      <ul>
        <li><span class="channel-badge"><ChannelLogo id="github-trending" />GitHub急成長リポ</span><span class="schedule-freq">月曜 8時頃</span></li>
      </ul>
    </div>
  </div>
  <main>
    <div class="filters">
      <div class="filter-group">
        <label>Channel</label>
        <div class="channel-tabs" role="group" aria-label="Channel filter">
          <button class="tab active" data-channel="all" aria-pressed="true">All</button>
          {channels.map((ch) => (
            <button class="tab" data-channel={ch} aria-pressed="false">{ch}</button>
          ))}
        </div>
      </div>
      <div class="filter-group">
        <label>Period</label>
        <div class="date-range">
          <label class="date-label" for="date-from">From</label>
          <input type="date" id="date-from" />
          <label class="date-label" for="date-to">to</label>
          <input type="date" id="date-to" />
          <button id="date-reset" class="reset-btn">Reset</button>

        </div>
      </div>
      <div class="filter-group">
        <label>Importance</label>
        <div class="importance-tabs" role="group" aria-label="Importance filter">
          <button class="imp-tab active" data-min="0" aria-pressed="true">All</button>
          <button class="imp-tab" data-min="3" aria-pressed="false" aria-label="注目度 3以上">★3+</button>
          <button class="imp-tab" data-min="4" aria-pressed="false" aria-label="注目度 4以上">★4+</button>
          <button class="imp-tab" data-min="5" aria-pressed="false" aria-label="注目度 5">★5</button>
        </div>
      </div>
      <div class="filter-group">
        <label>Sort</label>
        <button class="sort-btn" id="sort-toggle" data-order="desc">Newest first</button>
      </div>
      <div class="filter-group">
        <label>Search</label>
        <div id="search"></div>
      </div>
    </div>

    {sorted.length === 0 ? (
      <p class="no-results">No reports yet.</p>
    ) : (
      <ul class="report-list" id="report-list">
        {sorted.map((report) => {
          const dateStr = report.data.date.toISOString().slice(0, 10);
          return (
            <li data-channel={report.data.channel} data-date={dateStr} data-importance={report.data.importance || 0}>
              <span class="channel-badge">
                <ChannelLogo id={report.data.channelId} />
                {report.data.channel}
              </span>
              {report.data.importance && (
                <span class="importance-badge" aria-label={`注目度 ${report.data.importance}/5`}>
                  <span aria-hidden="true">{Array.from({ length: report.data.importance }).map(() => '★').join('')}</span>
                </span>
              )}
              <a href={`/reports/${report.id}/`}>{report.data.title}</a>
              <span class="date">{dateStr}</span>
            </li>
          );
        })}
      </ul>
    )}
    <p class="no-results" id="no-results" style="display:none;">No matching reports.</p>
  </main>
</Base>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script is:inline src="/pagefind/pagefind-ui.js"></script>
<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    new PagefindUI({
      element: '#search',
      showSubResults: true,
      showImages: false,
      translations: {
        placeholder: 'Search reports...',
        zero_results: 'No results for "[SEARCH_TERM]"',
      },
    });
  });
</script>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab');
  const impTabs = document.querySelectorAll<HTMLButtonElement>('.imp-tab');
  const dateFrom = document.getElementById('date-from') as HTMLInputElement;
  const dateTo = document.getElementById('date-to') as HTMLInputElement;
  const dateReset = document.getElementById('date-reset');
  const reportList = document.getElementById('report-list') as HTMLUListElement;
  const items = document.querySelectorAll<HTMLLIElement>('.report-list li');
  const noResults = document.getElementById('no-results');
  const sortToggle = document.getElementById('sort-toggle') as HTMLButtonElement;

  let activeChannel = 'all';
  let sortOrder = 'desc';
  let minImportance = 0;

  // 初期値: 当月1日
  const now = new Date();
  const pad = (n: number) => String(n).padStart(2, '0');
  dateFrom.value = `${now.getFullYear()}-${pad(now.getMonth() + 1)}-01`;
  dateTo.value = `${now.getFullYear()}-${pad(now.getMonth() + 1)}-${pad(now.getDate())}`;

  function applyFilters() {
    const from = dateFrom.value;
    const to = dateTo.value;
    let visibleCount = 0;

    items.forEach((item) => {
      const ch = item.dataset.channel;
      const date = item.dataset.date!;
      const imp = parseInt(item.dataset.importance || '0', 10);

      const matchChannel = activeChannel === 'all' || ch === activeChannel;
      const matchFrom = !from || date >= from;
      const matchTo = !to || date <= to;
      const matchImp = minImportance === 0 || imp >= minImportance;

      if (matchChannel && matchFrom && matchTo && matchImp) {
        item.style.display = '';
        visibleCount++;
      } else {
        item.style.display = 'none';
      }
    });

    if (noResults) {
      noResults.style.display = visibleCount === 0 ? '' : 'none';
    }
  }

  function applySortOrder() {
    const sorted = Array.from(items).sort((a, b) => {
      const da = a.dataset.date!;
      const db = b.dataset.date!;
      return sortOrder === 'desc' ? (db > da ? 1 : -1) : (da > db ? 1 : -1);
    });
    sorted.forEach((item) => reportList.appendChild(item));
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => {
        t.classList.remove('active');
        t.setAttribute('aria-pressed', 'false');
      });
      tab.classList.add('active');
      tab.setAttribute('aria-pressed', 'true');
      activeChannel = tab.dataset.channel!;
      applyFilters();
    });
  });

  sortToggle.addEventListener('click', () => {
    sortOrder = sortOrder === 'desc' ? 'asc' : 'desc';
    sortToggle.textContent = sortOrder === 'desc' ? 'Newest first' : 'Oldest first';
    sortToggle.dataset.order = sortOrder;
    applySortOrder();
  });

  impTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      impTabs.forEach((t) => {
        t.classList.remove('active');
        t.setAttribute('aria-pressed', 'false');
      });
      tab.classList.add('active');
      tab.setAttribute('aria-pressed', 'true');
      minImportance = parseInt(tab.dataset.min || '0', 10);
      applyFilters();
    });
  });

  applyFilters();

  dateFrom.addEventListener('change', applyFilters);
  dateTo.addEventListener('change', applyFilters);
  dateReset?.addEventListener('click', () => {
    dateFrom.value = '';
    dateTo.value = '';
    applyFilters();
  });
</script>
