import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const reports = await getCollection('reports');
const sorted = reports.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const channelOrder = ['Claude / Anthropic', 'Codex / OpenAI', '生成AIトレンド総合', 'GitHub急成長リポ'];
const channels = channelOrder.filter(ch =>
  sorted.some(r => r.data.channel === ch)
);

